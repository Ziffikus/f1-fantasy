# Supabase Konfiguration
# Diese Werte findest du in deinem Supabase Dashboard unter:
# Project Settings → API

VITE_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

